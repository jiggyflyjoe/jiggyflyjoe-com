<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>Cat Name Generator</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Josefin+Slab:wght@400;700&family=Syne+Mono&display=swap" rel="stylesheet" />
        <script src="https://kit.fontawesome.com/f8160d101d.js" crossorigin="anonymous"></script>
    </head>

    <body>
        <div class="stars" id="stars">
        </div>

        <main>
            <div class="header">
                <p class="subtitle">powered by the real-life council of kitties</p>
                <h1>Cat Name<br><span class="accent">Generator</span></h1>
                <p class="lore">
                    Deep within the household of jiggyflyjoe live four ancient beings:<br>
                    <strong>Tigger. Rufus. Cinnamon. Inky.</strong><br>
                    Their names hold mystical power. This generator harnesses it.
                </p>
            </div>
            <div class="generator-card">
                <div class="name-display" id="nameDisplay">
                    <span class="name-text" id="nameText">???</span>
                    <span class="name-origin" id="nameOrigin"></span>
                </div>
                <div class="buttons">
                    <button class="btn-generate" id="generateBtn" onclick="generateName()">
                        <i class="fa-solid fa-paw"></i> Generate Name
                    </button>
                    <button class="btn-copy" id="copyBtn" onclick="copyName()" disabled>
                        <i class="fa-regular fa-copy"></i> Copy
                    </button>
                </div>
                <div class="favorites-section">
                    <h2>Saved Names <span class="fav-count" id="favCount">0</span></h2>
                    <ul class="favorites-list" id="favoritesList">
                        <li class="empty-state">Generate a name, then save your favorites!</li>
                    </ul>
                    <button class="btn-clear" id="clearBtn" onclick="clearFavorites()" style="display:none">
                        Clear All
                    </button>
                </div>
            </div>
            <footer>
                <a href="/">← back to jiggyflyjoe.com</a>
            </footer>
        </main>
        <script is:inline>
            const catSyllables = {
                Tigger: ["Tig", "Tigg", "Ger", "Ig", "Tiggy"],
                Rufus: ["Ru", "Ruf", "Fus", "Us", "Rufie", "Fussie"],
                Cinnamon: ["Cin", "Sin", "Na", "Mon", "Inn", "Amon", "Cinny", "Simmons", "Simmon"],
                Inky: ["Ink", "In", "Ky", "Inki", "Inkster", "Inkspot", "Spot", "Inkwell"],
            };

            const allSyllables = Object.values(catSyllables).flat();
            let currentName = "";
            let favorites = JSON.parse(localStorage.getItem("catNameFavorites") || "[]");
            
            function generateName() {
                const length = Math.random() < 0.5 ? 2 : 3;
                const picked = [];

                for (let i = 0; i < length; i++) {
                    const randomIndex = Math.floor(Math.random() * allSyllables.length);
                    picked.push(allSyllables[randomIndex]);
                }

                const rawName = picked.join("").toLowerCase();
                currentName = rawName.charAt(0).toUpperCase() + rawName.slice(1);

                const contributors = [];
                for (const [cat, syllables] of Object.entries(catSyllables)) {
                    if (picked.some(p => syllables.includes(p))) {
                        contributors.push(cat);
                    }
                }

                const nameEl = document.getElementById("nameText");
                const originEl = document.getElementById("nameOrigin");
                const copyBtn = document.getElementById("copyBtn");

                nameEl.textContent = currentName;
                nameEl.classList.remove("pop");
                void nameEl.offsetWidth;
                nameEl.classList.add("pop");

                originEl.textContent = contributors.length > 0
                    ? `channeling: ${contributors.join(" + ")}`
                    : "channeling: the void";
                
                copyBtn.disabled = false;

                updateSaveButton();
            }

            function copyName() {
                if (!currentName) return;
                navigator.clipboard.writeText(currentName).then(() => {
                    const btn = document.getElementById("copyBtn");
                    btn.textContent = "Copied!";
                    setTimeout(() => { btn.textContent = "Copy"; }, 1500);
                });
            }

            function updateSaveButton() {
                let saveBtn = document.getElementById("saveBtn");
                if (!saveBtn) {
                    saveBtn = document.createElement("button");
                    saveBtn.id = "saveBtn";
                    saveBtn.className = "btn-save";
                    saveBtn.onclick = saveFavorite;
                    document.getElementById("nameDisplay").appendChild(saveBtn);
                }
                const alreadySaved = favorites.includes(currentName);
                saveBtn.textContent = alreadySaved ? "✓ Saved" : "Save";
                saveBtn.disabled = alreadySaved;
            }

            function saveFavorite() {
                if (!currentName || favorites.includes(currentName)) return;
                favorites.push(currentName);
                localStorage.setItem("catNameFavorites", JSON.stringify(favorites));
                renderFavorites();
                updateSaveButton();
            }

            function removeFavorite(name) {
                favorites = favorites.filter(f => f !== name);
                localStorage.setItem("catNameFavorites", JSON.stringify(favorites));
                renderFavorites();
                if (currentName === name) updateSaveButton();
            }

            function renderFavorites() {
                const list = document.getElementById("favoritesList");
                const count = document.getElementById("favCount");
                const clearBtn = document.getElementById("clearBtn");

                count.textContent = favorites.length;
                clearBtn.style.display = favorites.length > 0 ? "inline-block" : "none";

                if (favorites.length === 0) {
                    list.innerHTML = '<li class="empty-state">Generate a name, then save your favorites!</li>';
                    return;
                }

                list.innerHTML = favorites.map(name => `
                    <li>
                        <span>${name}</span>
                        <button class="remove-btn" onclick="removeFavorite('${name}')">✕</button>
                    </li>
                `).join("");
            }

            function makeStars() {
                const container = document.getElementById("stars");
                for (let i = 0; i < 60; i++) {
                    const star = document.createElement("div");
                    star.className = "star";
                    star.style.left = Math.random() * 100 + "vw";
                    star.style.top = Math.random() * 100 + "vh";
                    star.style.animationDelay = Math.random() * 4 + "s";
                    star.style.width = star.style.height = (Math.random() * 3 + 1) + "px";
                    container.appendChild(star);
                }
            }

            makeStars();
            renderFavorites();
        </script>
        <style>
            :root {
                --bg: #0e0b14;
                --surface: #1a1526;
                --border: #2e2640;
                --accent: #e8e87c;
                --accent2: #b48cf5;
                --text: #ede8f5;
                --muted: #7a6e8a;
                --font-display: "Josefin Slab", serif;
                --font-mono: "Syne Mono", monospace;
            }

            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                background: var(--bg);
                color: var(--text);
                font-family: var(--font-display);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                overflow-x: hidden;
            }

            .stars {
                position: fixed;
                inset: 0;
                pointer-events: none;
                z-index: 0;
            }

            .star {
                position: absolute;
                background: white;
                border-radius: 50%;
                opacity: 0.3;
                animation: twinkle 3s infinite alternate;
            }

            @keyframes twinkle {
                from {
                    opacity: 0.1;
                    transform: scale(1);
                }
                to {
                    opacity: 0.7;
                    transform: scale(1.4);
                }
            }

            main {
                position: relative;
                z-index: 1;
                width: min(600px, 92vw);
                padding: 3rem 0 2rem;
                display: flex;
                flex-direction: column;
                gap: 2rem;
            }

            .header {
                text-align: center;
            }

            .subtitle {
                font-family: var(--font-mono);
                font-size: 0.75rem;
                color: var(--accent);
                letter-spacing: 0.2em;
                text-transform: uppercase;
                margin-bottom: 0.5rem;
            }

            h1 {
                font-size: clamp(2.5rem, 10vw, 4.5rem);
                line-height: 1;
                font-weight: 700;
                letter-spacing: -0.02em;
            }

            .accent {
                color: var(--accent2);
            }

            .lore {
                margin-top: 1rem;
                font-size: 0.9rem;
                color: var(--muted);
                line-height: 1.6;
            }

            .lore strong {
                color: var(--accent);
            }

            .generator-card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 1rem;
                padding: 2rem;
                display: flex;
                flex-direction: column;
                gap: 1.5rem;
            }

            .name-display {
                min-height: 7rem;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 0.5rem;
                border: 1px dashed var(--border);
                border-radius: 0.75rem;
                padding: 1.5rem;
                position: relative;
            }

            .name-text {
                font-size: clamp(2rem, 8vw, 3.5rem);
                font-weight: 700;
                color: var(--accent2);
                letter-spacing: 0.05em;
                transition: color 0.2s;
            }

            .name-text.pop {
                animation: pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            }

            @keyframes pop {
                from {
                    transform: scale(0.8);
                    opacity: 0.5;
                }
                to {
                    transform: scale(1);
                    opacity: 1;
                }
            }

            .name-origin {
                font-family: var(--font-mono);
                font-size: 0.7rem;
                color: var(--muted);
                letter-spacing: 0.1em;
            }

            .buttons {
                font-family: var(--font-display);
                cursor: pointer;
                border: none;
                border-radius: 0.5rem;
                font-size: 1rem;
                font-weight: 700;
                transition: transform 0.1s, opacity 0.1s;
            }

            button:active {
                transform: scale(0.97);
            }

            button:disabled {
                opacity: 0.4;
                cursor: not-allowed;
            }

            .btn-generate {
                flex: 1;
                background: var(--accent);
                color: #0e0b14;
                padding: 0.85rem 1.5rem;
                letter-spacing: 0.05em;
            }

            .btn-generate:hover {
                opacity: 0.9;
            }

            .btn-copy {
                background: transparent;
                border: 1px solid var(--border);
                color: var(--text);
                padding: 0.85rem 1.25rem;
            }

            .btn-copy:hover:not(:disabled) {
                border-color: var(--accent2);
                color: var(--accent2);
            }

            .btn-save {
                position: absolute;
                top: 0.6rem;
                right: 0.6rem;
                background: transparent;
                border: 1px solid var(--border);
                color: var(--muted);
                padding: 0.3rem 0.7rem;
                font-size: 0.75rem;
                border-radius: 0.4rem;
            }

            .btn-save:hover:not(:disabled) {
                border-color: var(--accent2);
                color: var(--accent2);
            }

            .btn-save:disabled {
                color: var(--accent2);
                border-color: var(--accent2);
                opacity: 1;
            }

            .favorites-section {
                border-top: 1px solid var(--border);
                padding-top: 1.25rem;
            }

            .favorites-section h2 {
                font-size: 0.85rem;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--muted);
                margin-bottom: 0.75rem;
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

            .fav-count {
                background: var(--border);
                color: var(--accent2);
                border-radius: 999px;
                padding: 0.1em 0.5em;
                font-size: 0.75rem;
                font-family: var(--font-mono);
            }

            .favorites-list {
                list-style: none;
                display: flex;
                flex-wrap: wrap;
                gap: 0.5rem;
                margin-bottom: 0.75rem;
            }

            .favorites-list li {
                background: var(--bg);
                border: 1px solid var(--border);
                border-radius: 0.5rem;
                padding: 0.35rem 0.75rem;
                font-size: 0.9rem;
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

            .empty-state {
                color: var(--muted);
                font-size: 0.8rem;
                border: none !important;
                background: none !important;
            }

            .remove-btn {
                background: none;
                border: none;
                color: var(--muted);
                font-size: 0.7rem;
                padding: 0;
                line-height: 1;
            }

            .remove-btn:hover {
                color: var(--accent);
            }

            .btn-clear {
                background: none;
                border: 1px solid var(--border);
                color: var(--muted);
                padding: 0.3rem 0.75rem;
                font-size: 0.75rem;
                border-radius: 0.4rem;
            }

            .btn-clear:hover {
                border-color: var(--accent);
                color: var(--accent);
            }

            footer {
                text-align: center;
            }

            footer a {
                font-family: var(--font-mono);
                font-size: 0.75rem;
                color: var(--muted);
                text-decoration: none;
                letter-spacing: 0.1em;
            }

            footer a:hover {
                color: var(--accent2);
            }
        </style>
    </body>
</html>