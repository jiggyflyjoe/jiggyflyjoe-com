---
import Layout from '../layouts/layout.astro';
---

<Layout title="Home">
	<section class="hero">
		<div class="hero-text">
			<h1 class="hero-headline">Hey, I'm <span class="accent"><em>jiggyflyjoe</span></em>! <span class="wave">👋</span></h1>
			<p class="hero-content">You can call me “jiggy” or Joe. “jiggly” is factually incorrect, but still fine. I'm a gamer, content creator, blogger, media enthusiast, web dev in training, and proud cat dad to four furry little guys. I make calm, low-pressure content abut gaming, tech, and creative rambling in general for people who don't vibe with loud, angry internet culture.</p>
			<div class="hero-links">
				<a href="/blog" class="btn">Latest Posts</a>
				<a href="https://twitch.tv/jiggyflyjoe" class="btn btn-outline" target="_blank">Watch Live <i class="fa-solid fa-circle fa-beat"></i></a>
			</div>
		</div>
		<div class="hero-image">
			<img src="/PXL_20250818_2204133062-scaled.jpg" alt="jiggyflyjoe and his cat Rufus." />
		</div>
	</section>

	<section class="feed">
  <h2>Latest from <span class="accent">Bluesky</span></h2>
  <p class="feed-intro">What I've been posting lately.</p>

  <div class="feed-list" id="bluesky-feed">
    <p class="feed-loading">Loading posts...</p>
  </div>

  <div class="feed-footer">
    <a href="https://bsky.app/profile/jiggyflyjoe.com" target="_blank" class="btn btn-outline">
      <i class="fa-brands fa-bluesky"></i> Follow on Bluesky
    </a>
  </div>
</section>

<script is:inline>
  async function loadFeed() {
    const container = document.getElementById('bluesky-feed');
    try {
      const response = await fetch(
        'https://public.api.bsky.app/xrpc/app.bsky.feed.getAuthorFeed?actor=jiggyflyjoe.com&limit=6'
      );
      const data = await response.json();
      const posts = data.feed.filter(item => !item.post.record.reply);

      container.innerHTML = posts.map(item => {
        const post = item.post;
        const text = post.record.text;
        const date = new Date(post.record.createdAt).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        });
        const url = `https://bsky.app/profile/jiggyflyjoe.com/post/${post.uri.split('/').pop()}`;

        return `
          <a href="${url}" target="_blank" class="feed-card">
            <span class="post-date">${date}</span>
            <p>${text}</p>
            <span class="post-read">View on Bluesky →</span>
          </a>
        `;
      }).join('');
    } catch (error) {
      container.innerHTML = '<p class="feed-loading">Could not load posts. Check me out on Bluesky directly!</p>';
    }
  }

  loadFeed();
</script>
</Layout>